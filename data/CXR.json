                "options": ["None", "Right — small", "Right — moderate", "Right — large", "Left — small", "Left — moderate", "Left — large", "Bilateral", "Loculated", "Uncertain"]
              },
              {
                "item_id": "B_4_1",
                "item_text": "Pneumothorax",
