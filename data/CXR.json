          {
            "group_name": "Collapse / atelectasis",
            "items": [
              {
                "item_id": "B_3_0",
                "item_text": "Collapse / atelectasis",
                "type": "multi_select",
                "required": true,
                "options": ["Absent", "Right upper lobe", "Right middle lobe", "Right lower lobe", "Left upper lobe", "Lingula", "Left lower lobe", "Subsegmental / plate-like — right", "Subsegmental / plate-like — left", "Bilateral subsegmental"]
              }
