                  "trigger_option": "≥0.5 (enlarged)",
                  "reveals": {
                    "item_id": "C_0_0_desc",
                    "item_text": "Describe cardiomegaly",
                    "type": "describe",
                    "required": true,
                    "placeholder": "Describe degree and likely chamber(s) involved"
                  }
                }
              }
            ]
          },
          {
            "group_name": "Cardiac silhouette",
            "items": [
              {
                "item_id": "C_1_0",
                "item_text": "Cardiac silhouette",
                "type": "single_select",
                "required": true,
                "options": ["Normal contour", "Right heart border abnormality", "Left heart border abnormality", "Boot-shaped (RVH)", "Globular (pericardial effusion suspected)", "Post-operative"]
