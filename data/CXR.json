      "A": {
        "section_id": "A",
        "section_label": "Airway / Mediastinum",
        "section_note_placeholder": "Optional notes for Airway / Mediastinum",
        "groups": [
          {
            "group_name": "Trachea",
            "items": [
              {
                "item_id": "A_0_0",
                "item_text": "Trachea position",
                "type": "single_select",
                "required": true,
                "options": ["Midline", "Deviated right", "Deviated left", "Difficult to assess"]
              },
              {
                "item_id": "A_0_1",
                "item_text": "Carinal angle",
                "type": "single_select",
                "required": true,
                "options": ["Normal (<70°)", "Borderline 70–90°", "Clearly widened >90°", "Difficult to assess"]
              }
            ]
          },
          {
            "group_name": "Main bronchi",
            "items": [
              {
                "item_id": "A_1_0",
                "item_text": "Main bronchi",
                "type": "single_select",
                "required": true,
                "options": ["Unremarkable", "Right main bronchus abnormality", "Left main bronchus abnormality", "Bilateral abnormality"]
              }
            ]
          },
          {
            "group_name": "Mediastinum",
            "items": [
              {
                "item_id": "A_2_0",
                "item_text": "Mediastinal shift",
                "type": "single_select",
                "required": true,
                "options": ["Absent", "Shifted right", "Shifted left", "Difficult to assess"]
              },
              {
                "item_id": "A_2_1",
                "item_text": "Mediastinal width",
                "type": "describe",
                "required": true,
                "placeholder": "Describe — note: >8 cm threshold applies to PA erect only"
              },
              {
                "item_id": "A_2_2",
                "item_text": "Aortopulmonary (AP) window",
                "type": "single_select",
                "required": true,
                "options": ["Patent", "Obliterated", "Difficult to assess"]
              },
              {
                "item_id": "A_2_3",
                "item_text": "Aortic knob",
                "type": "describe",
                "required": true,
                "placeholder": "Describe — e.g. normal, calcified, enlarged, obscured"
              }
            ]
          },
          {
            "group_name": "ETT",
            "items": [
              {
                "item_id": "A_3_0",
                "item_text": "ETT",
                "type": "single_select",
                "required": false,
                "placeholder": "Complete only if ETT is present",
                "options": ["Not present", "Tip 3–5 cm above carina (optimal)", "Too high (>5 cm above carina)", "Too low (<3 cm above carina)", "Right mainstem bronchus", "Left mainstem bronchus"]
              }
            ]
          }
        ]
      },

      "B": {
        "section_id": "B",
        "section_label": "Breathing",
